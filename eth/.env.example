# for prod deployments, copy to .env and replace with your credentials

# deploys contracts; also used by scripts/send-eth.ts when ADMIN_PRIVATE_KEY is unset
DEPLOYER_MNEMONIC=change typical hire slam amateur loan grid fix drama electric seed label

# give game admin rights to a different address than deployer
# ADMIN_PUBLIC_ADDRESS=0x0000000000000000000000000000000000000000
# ADMIN_PRIVATE_KEY=
# ADMIN_MNEMONIC=
# optional fallback RPC when scripts/send-eth.ts is run without --network / --rpc
# RPC_URL=

# Optional deployment networks. Leave unset for local compile/test.
# ALTLAYER_RPC_URL=
# ALTLAYER_CHAINID=

# MEGAETH_RPC_URL=
# MEGAETH_CHAINID=

# REDSTONE_TESTNET_RPC_URL=https://rpc.holesky.redstone.xyz
# REDSTONE_TESTNET_CHAINID=17001

# REDSTONE_RPC_URL=
# REDSTONE_CHAINID=
